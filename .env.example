# Vapi
VAPI_API_KEY=
VAPI_SECRET=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# GBrain (https://github.com/garrytan/gbrain) — knowledge graph
#
# Three modes (auto-detected, or set explicitly):
#   file   = local markdown filesystem (default, used for offline/demo)
#   api    = remote GBrain MCP server only (fails if server unreachable)
#   hybrid = api primary, file as cache + fallback (recommended for demos)
#
# To run a local GBrain server:
#   npm i -g @garrytan/gbrain
#   gbrain init
#   gbrain serve --http        # prints bearer token + URL
#   then set the three vars below
GBRAIN_API_KEY=
GBRAIN_BASE_URL=
GBRAIN_PROJECT_ID=default
GBRAIN_MODE=

# GStack — async ingest/review pipeline
GSTACK_API_KEY=
GSTACK_BASE_URL=
GSTACK_PROJECT_ID=

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
DEMO_PHONE=+1XXXXXXXXXX
NODE_ENV=development
