# Production deploy
FRONTEND_URL=https://web-five-ruby-11.vercel.app
DEMO_PHONE=+13203648288

# Vapi dashboard/API
VAPI_API_KEY=
VAPI_SECRET=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# Convex persistence
CONVEX_URL=
CONVEX_DEPLOYMENT=
# This branch defaults to no Convex writes while real local GBrain is being tested.
CONVEX_WRITE_ENABLED=false

# Real local GBrain CLI integration. Keep disabled unless testing this branch locally.
GBRAIN_LOCAL_ENABLED=false
GBRAIN_CLI_PATH=gbrain
GBRAIN_IMPORT_DIR=
GBRAIN_IMPORT_WORKERS=4
GBRAIN_CATALOG_IMPORT_LIMIT=

# Optional sponsor sync; missing values never block the demo.
GBRAIN_API_KEY=
GBRAIN_BASE_URL=
GBRAIN_PROJECT_ID=
GSTACK_API_KEY=
GSTACK_BASE_URL=
GSTACK_PROJECT_ID=

# Local catalog overrides. Production uses committed yc-gbrain/server/data files.
COSTCO_CATALOG_PATH=
STARBUCKS_CATALOG_PATH=
COSTCO_TAXONOMY_PATH=
STARBUCKS_TAXONOMY_PATH=
