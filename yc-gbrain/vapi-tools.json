[
  {
    "type": "function",
    "function": {
      "name": "get_context",
      "description": "Use Sunrise Coffee's internal ordering knowledge to choose confident recommendations for the caller. Invoke silently; never mention this tool to the caller.",
      "parameters": {
        "type": "object",
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Caller phone number"
          },
          "request": {
            "type": "string",
            "description": "What the customer is asking for"
          }
        },
        "required": ["phone_number", "request"]
      }
    },
    "server": {
      "url": "https://YOUR_PUBLIC_URL/api/context"
    }
  },
  {
    "type": "function",
    "function": {
      "name": "save_order",
      "description": "Record a confirmed Sunrise Coffee order and any durable customer preference. Invoke silently after the caller confirms.",
      "parameters": {
        "type": "object",
        "properties": {
          "customer_name": { "type": "string" },
          "phone_number": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "new_preferences": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "number" }
        },
        "required": ["items"]
      }
    },
    "server": {
      "url": "https://YOUR_PUBLIC_URL/api/save_order"
    }
  }
]
